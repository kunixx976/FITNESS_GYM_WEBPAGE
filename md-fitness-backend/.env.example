# ── DATABASE ──────────────────────────────────────────────
# Get free PostgreSQL from https://neon.tech
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

# ── REDIS ─────────────────────────────────────────────────
# Get free Redis from https://upstash.com
REDIS_URL=redis://default:password@host:port

# ── AUTH ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-256-bit-key-here
JWT_EXPIRES_IN=8h

# ── ADMIN ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@mdfitnessgym.in
# Generate hash: node -e "const b=require('bcryptjs');b.hash('yourpass',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── WHATSAPP ──────────────────────────────────────────────
# Get from https://business.whatsapp.com/products/business-platform
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-number-id

# ── APP ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://mdfitnessgym.netlify.app


# ── MONITORING ────────────────────────────────────────────
# Get from https://sentry.io (free tier)
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
